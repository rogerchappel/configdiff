{
  "name": "configdiff",
  "version": "0.1.0",
  "description": "Find config drift across environments — compare .env, JSON, YAML, and INI files for missing keys, conflicting values, and severity-ranked diffs",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "configdiff": "./dist/cli.js"
  },
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "SECURITY.md",
    "CHANGELOG.md",
    "CONTRIBUTING.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "node --test dist/test/*.test.js",
    "smoke": "node dist/cli.js fixtures/env-matching.dev.env fixtures/env-matching.prod-copy.env && echo 'smoke OK'",
    "lint": "tsc --noEmit",
    "check": "npm run lint && npm test",
    "package:smoke": "npm run build && npm pack --dry-run",
    "release:check": "npm run build && npm run check && npm run smoke && npm run package:smoke"
  },
  "keywords": [
    "config",
    "diff",
    "dotenv",
    "yaml",
    "json",
    "ini",
    "drift",
    "environments",
    "devops",
    "configuration",
    "compare",
    "cli"
  ],
  "author": "Roger Chappel",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rogerchappel/configdiff.git"
  },
  "bugs": {
    "url": "https://github.com/rogerchappel/configdiff/issues"
  },
  "homepage": "https://github.com/rogerchappel/configdiff#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2"
  },
  "dependencies": {
    "yaml": "^2.6.1"
  }
}
